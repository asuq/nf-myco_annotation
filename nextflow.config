manifest {
    name = 'nf-annotation'
    version = '0.1.0'
    nextflowVersion = '>=26.04.0'
}

params {
    sample_csv = null
    metadata = null
    taxdump = null
    taxdump_label = null
    checkm2_db = null
    checkm2_db_label = null
    codetta_db = null
    codetta_db_label = null
    eggnog_db = null
    eggnog_db_label = null
    eggnog_only_accessions = null
    barrnap_kingdom = 'bac'
    busco_lineages = ['bacillota_odb12', 'mycoplasmatota_odb12']
    busco_primary_column = null
    busco_db = null
    prepare_busco_datasets = false
    download_missing_databases = false
    force_runtime_database_rebuild = false
    runtime_db_scratch_root = null
    taxdump_version = null
    codetta_extra_args = ''
    ccfinder_extra_args = ''
    padloc_extra_args = ''
    eggnog_extra_args = ''
    ani_allow_incomplete_16s = false
    ani_threshold = 0.95
    ani_score_profile = 'default'
    gcode_rule = 'strict_delta'
    outdir = 'results'
    task_attempts = 3
    soft_fail_attempts = 3
    db_download_attempts = 2
    max_cpus = 8
    max_memory = 64.GB
    max_time = 24.h
    slurm_queue = null
    slurm_qos = null
    slurm_cluster_options = null
    executor_queue_size = 100
    singularity_cache_dir = null
    singularity_run_options = ''
    python_container = 'quay.io/asuq1617/python-scipy:3.12'
    runtime_db_helper_container = 'quay.io/asuq1617/nf-myco_db:0.3'
    seqtk_container = 'quay.io/biocontainers/seqtk:1.5--h577a1d6_1'
    barrnap_container = 'quay.io/biocontainers/barrnap:0.9--hdfd78af_4'
    checkm2_container = 'quay.io/biocontainers/checkm2:1.1.0--pyh7e72e81_1'
    busco_container = 'quay.io/biocontainers/busco:6.0.0--pyhdfd78af_2'
    prokka_container = 'quay.io/asuq1617/prokka:1.15.6'
    ccfinder_container = 'quay.io/asuq1617/ccfinder:4.2.30'
    codetta_container = 'quay.io/asuq1617/codetta:2.0'
    padloc_container = 'quay.io/asuq1617/padloc:2.0.0'
    eggnog_container = 'quay.io/asuq1617/eggnog-mapper:2.1.13'
    fastani_container = 'quay.io/biocontainers/fastani:1.34--hb66fcc3_7'
}

includeConfig 'conf/base.config'
includeConfig 'conf/debug.config'
includeConfig 'conf/local.config'
includeConfig 'conf/slurm.config'
includeConfig 'conf/test.config'
includeConfig 'conf/docker.config'
includeConfig 'conf/singularity.config'
includeConfig 'conf/oist.config'
includeConfig 'conf/gwdg.config'
includeConfig 'conf/marmic.config'

profiles {
    local {
        process.executor = 'local'
    }

    docker {
        docker.enabled = true
    }

    slurm {
        process.executor = 'slurm'
    }

    test {
        process.executor = 'local'
    }

    singularity {
        singularity.enabled = true
    }
}
