profiles {
    slurm {
        process.executor = 'slurm'
        executor.queueSize = params.executor_queue_size
        process.queue = params.slurm_queue
        process.clusterOptions = {
            if (params.slurm_cluster_options instanceof Boolean) {
                throw new IllegalArgumentException(
                    "params.slurm_cluster_options must be a string. Use --slurm_qos 2h or --slurm_cluster_options='--qos=2h'."
                )
            }
            [
                params.slurm_qos ? "--qos=${params.slurm_qos}" : null,
                params.slurm_cluster_options ?: null,
            ]
                .findAll { option -> option != null && option.toString().trim() }
                .join(' ')
        }
    }
}

process {
    withLabel: process_medium {
        cpus = { Math.min(16 * task.attempt, params.max_cpus as int) }
        memory = { [64.GB * task.attempt, params.max_memory].min() }
        time = { [12.h * task.attempt, params.max_time].min() }
    }

    withLabel: process_high {
        cpus = { Math.min(64 * task.attempt, params.max_cpus as int) }
        memory = { [200.GB * task.attempt, params.max_memory].min() }
        time = { [24.h * task.attempt, params.max_time].min() }
    }
}
