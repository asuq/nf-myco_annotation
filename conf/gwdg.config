def buildSlurmClusterOptions = { List defaults = [] ->
    if (params.slurm_cluster_options instanceof Boolean) {
        throw new IllegalArgumentException(
            "params.slurm_cluster_options must be a string. Use --slurm_qos 2h or --slurm_cluster_options='--qos=2h'."
        )
    }
    def qosOption = params.slurm_qos ? "--qos=${params.slurm_qos}" : null
    (defaults + [qosOption, params.slurm_cluster_options ?: null])
        .findAll { it != null && it.toString().trim() }
        .join(' ')
}

profiles {
    gwdg {
        params {
            config_profile_description = 'The GWDG SCC HPC profile with SLURM, Singularity, and SHM-first temporary storage.'
            config_profile_contact = 'GWDG SCC user profile'
            config_profile_url = 'https://docs.hpc.gwdg.de/how_to_use/storage_systems/temporary_storage/index.html'
            max_memory = 2.TB
            max_cpus = 96
            max_time = 48.h
        }

        process.executor = 'slurm'
        executor.queueSize = params.executor_queue_size
        process.queue = params.slurm_queue ?: 'scc-cpu'
        process.clusterOptions = buildSlurmClusterOptions(['--export=ALL', '-C ssd'])
        process.resourceLimits = [
            memory: 2.TB,
            cpus: 96,
            time: 48.h,
        ]
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = params.singularity_cache_dir ?: '/projects/scc/MPG/MBMM/scc_mbmm_harder_/dir.project/Softwares/nfx_singularity_cache'
        singularity.pullTimeout = '4h'
        docker.enabled = false
        process.containerOptions = params.singularity_run_options ?: ''
        process.scratch = '$LOCAL_TMPDIR'
        process.stageOutMode = 'copy'
        process.beforeScript = {
            def tempRoot = task.attempt == 1
                ? '${SHM_TMPDIR:-${LOCAL_TMPDIR:-${SHARED_SSD_TMPDIR:-${SHARED_TMPDIR:-/tmp}}}}'
                : '${LOCAL_TMPDIR:-${SHARED_SSD_TMPDIR:-${SHARED_TMPDIR:-/tmp}}}'
            [
                'module load apptainer',
                "temp_root=\"${tempRoot}\"",
                'export TMPDIR="${temp_root}"',
                'export TMP="${temp_root}"',
                'export TEMP="${temp_root}"',
                'export TEMPDIR="${temp_root}"',
                'export APPTAINERENV_TMPDIR="${temp_root}"',
                'export SINGULARITYENV_TMPDIR="${temp_root}"',
                'export APPTAINERENV_TMP="${temp_root}"',
                'export SINGULARITYENV_TMP="${temp_root}"',
            ].join('\n')
        }

        process {
            withLabel: process_medium {
                cpus = { Math.min(16 * task.attempt, params.max_cpus as int) }
                memory = { [50.GB * task.attempt, params.max_memory].min() }
                time = { [6.h * task.attempt, params.max_time].min() }
            }

            withLabel: process_high {
                cpus = { Math.min(64 * task.attempt, params.max_cpus as int) }
                memory = { [200.GB * task.attempt, params.max_memory].min() }
                time = { [1.d * task.attempt, params.max_time].min() }
            }

            withName: PROKKA {
                container = params.prokka_container
                stageInMode = 'copy'
            }

            withName: CALCULATE_ASSEMBLY_STATS {
                container = params.seqtk_container
                cpus = { Math.min(4 * task.attempt, params.max_cpus as int) }
                memory = { [8.GB * task.attempt, params.max_memory].min() }
                time = { [4.h * task.attempt, params.max_time].min() }
                stageInMode = 'copy'
            }
        }
    }
}
