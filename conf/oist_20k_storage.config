/*
 * Opt-in OIST runtime overrides for large cohorts. Use with `-profile oist`
 * and pass `-work-dir` explicitly so resumed runs reuse the same persistent
 * work directory.
 */
process {
    queue = 'short'
    scratch = '/scratch'
    stageOutMode = 'move'

    withName: STAGE_INPUTS {
        executor = 'slurm'
    }

    // Keep the prepared ANI inputs on shared storage so hard links can target
    // the staged FASTAs.
    withName: BUILD_FASTANI_INPUTS {
        scratch = false
        queue = 'short'
    }

    // Keep the second FastANI copy on node-local scratch only.
    withName: FASTANI {
        queue = 'compute'
        time = 2.d
        scratch = '/scratch'
        stageInMode = 'copy'
        stageOutMode = 'move'
    }

    withName: CLUSTER_ANI {
        queue = 'compute'
        time = 12.h
    }

    withName: SELECT_ANI_REPRESENTATIVES {
        queue = 'compute'
        time = 12.h
    }
}
