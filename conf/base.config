params.standardMaxRetries = { Math.max((params.task_attempts as int) - 1, 0) }
params.dbDownloadMaxRetries = { Math.max((params.db_download_attempts as int) - 1, 0) }

process {
    shell = ['/bin/bash', '-euo', 'pipefail']
    executor = 'local'
    errorStrategy = 'retry'
    maxRetries = { params.standardMaxRetries instanceof Closure ? params.standardMaxRetries() : params.standardMaxRetries }
    maxErrors = -1
    cpus = { Math.min(1, params.max_cpus as int) }
    memory = { [2.GB * task.attempt, params.max_memory].min() }
    time = { [1.h * task.attempt, params.max_time].min() }

    withLabel: process_single {
        cpus = { Math.min(1, params.max_cpus as int) }
        memory = { [2.GB * task.attempt, params.max_memory].min() }
        time = { [1.h * task.attempt, params.max_time].min() }
    }

    withLabel: process_small {
        cpus = { Math.min(2 * task.attempt, params.max_cpus as int) }
        memory = { [4.GB * task.attempt, params.max_memory].min() }
        time = { [2.h * task.attempt, params.max_time].min() }
    }

    withLabel: process_medium {
        cpus = { Math.min(4 * task.attempt, params.max_cpus as int) }
        memory = { [8.GB * task.attempt, params.max_memory].min() }
        time = { [4.h * task.attempt, params.max_time].min() }
    }

    withLabel: process_high {
        cpus = { Math.min(8 * task.attempt, params.max_cpus as int) }
        memory = { [32.GB * task.attempt, params.max_memory].min() }
        time = { [12.h * task.attempt, params.max_time].min() }
    }

    withName: VALIDATE_INPUTS {
        container = params.python_container
    }

    withName: STAGE_INPUTS {
        container = params.seqtk_container
    }

    withName: CALCULATE_ASSEMBLY_STATS {
        container = params.seqtk_container
    }

    withName: BARRNAP {
        container = params.barrnap_container
    }

    withName: CHECKM2 {
        container = params.checkm2_container
    }

    withName: ASSIGN_GCODE_AND_QC {
        container = params.python_container
    }

    withName: TAXONOMY_EXPAND {
        container = params.python_container
    }

    withName: SUMMARISE_16S {
        container = params.python_container
    }

    withName: BUILD_OUTPUT_CONTRACTS {
        container = params.python_container
    }

    withName: PUBLISH_COHORT_16S {
        container = params.python_container
    }

    withName: DOWNLOAD_BUSCO_DATASET {
        errorStrategy = 'retry'
        maxRetries = { params.dbDownloadMaxRetries instanceof Closure ? params.dbDownloadMaxRetries() : params.dbDownloadMaxRetries }
        container = params.busco_container
    }

    withLabel: prep_taxdump_database {
        errorStrategy = 'retry'
        maxRetries = { params.dbDownloadMaxRetries instanceof Closure ? params.dbDownloadMaxRetries() : params.dbDownloadMaxRetries }
        container = 'quay.io/asuq1617/nf-myco_db:0.3'
    }

    withLabel: prep_codetta_database {
        errorStrategy = 'retry'
        maxRetries = { params.dbDownloadMaxRetries instanceof Closure ? params.dbDownloadMaxRetries() : params.dbDownloadMaxRetries }
        container = 'quay.io/asuq1617/nf-myco_db:0.3'
    }

    withLabel: download_checkm2_database {
        errorStrategy = 'retry'
        maxRetries = { params.dbDownloadMaxRetries instanceof Closure ? params.dbDownloadMaxRetries() : params.dbDownloadMaxRetries }
        container = params.checkm2_container
    }

    withLabel: download_busco_databases {
        errorStrategy = 'retry'
        maxRetries = { params.dbDownloadMaxRetries instanceof Closure ? params.dbDownloadMaxRetries() : params.dbDownloadMaxRetries }
        container = params.busco_container
    }

    withLabel: download_eggnog_database {
        errorStrategy = 'retry'
        maxRetries = { params.dbDownloadMaxRetries instanceof Closure ? params.dbDownloadMaxRetries() : params.dbDownloadMaxRetries }
        container = params.eggnog_container
    }

    withLabel: finalise_runtime_database {
        container = 'quay.io/asuq1617/nf-myco_db:0.3'
    }

    withLabel: merge_runtime_database_reports {
        container = 'quay.io/asuq1617/nf-myco_db:0.3'
    }

    withName: BUSCO {
        container = params.busco_container
    }

    withName: PROKKA {
        container = params.prokka_container
    }

    withName: CCFINDER {
        container = params.ccfinder_container
    }

    withName: CODETTA {
        container = params.codetta_container
    }

    withName: SUMMARISE_CODETTA {
        container = params.python_container
    }

    withName: SUMMARISE_CCFINDER {
        container = params.python_container
    }

    withName: PADLOC {
        container = params.padloc_container
    }

    withName: EGGNOG {
        container = params.eggnog_container
    }

    withName: SUMMARISE_BUSCO {
        container = params.python_container
    }

    withName: BUILD_FASTANI_INPUTS {
        container = params.python_container
    }

    withName: FASTANI {
        container = params.fastani_container
    }

    withName: CLUSTER_ANI {
        container = params.python_container
    }

    withName: SELECT_ANI_REPRESENTATIVES {
        container = params.python_container
    }

    withName: BUILD_MASTER_TABLE {
        container = params.python_container
    }

    withName: WRITE_SAMPLE_STATUS {
        container = params.python_container
    }

    withName: COLLECT_VERSIONS {
        container = params.python_container
    }
}

timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/trace.tsv"
    overwrite = true
}

dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/dag.html"
    overwrite = true
}
