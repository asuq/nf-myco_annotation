profiles {
    test {
        params {
            sample_csv = "${projectDir}/assets/tables/stub/sample_sheet.csv"
            metadata = "${projectDir}/assets/tables/stub/metadata.tsv"
            taxdump = "${projectDir}/assets/fixtures/stub/taxdump"
            taxdump_label = "stub-taxdump"
            checkm2_db = "${projectDir}/assets/fixtures/stub/checkm2_db"
            checkm2_db_label = "stub-checkm2-db"
            busco_db = "${projectDir}/assets/fixtures/stub/busco"
            codetta_db = "${projectDir}/assets/fixtures/stub/codetta_db"
            codetta_db_label = "stub-codetta-db"
            eggnog_db = "${projectDir}/assets/fixtures/stub/eggnog_db"
            eggnog_db_label = "stub-eggnog-db"
            outdir = "${projectDir}/results-test"
            max_cpus = 2
            max_memory = 4.GB
            max_time = 2.h
        }
    }
}
